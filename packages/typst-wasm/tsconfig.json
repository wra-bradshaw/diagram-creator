{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["tsdown-plugin-worker/types", "vitest/globals"]
  },
  "include": ["src/**/*", "tests/**/*"]
}
