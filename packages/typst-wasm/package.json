{
  "name": "typst-wasm",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:wasm": "wasm-pack build --target web --out-dir src/wasm . -- -Z build-std=std,panic_abort",
    "build": "bun run build:wasm && node scripts/patch_wasm_import.cjs && tsdown && cp -r src/wasm dist/wasm",
    "dev": "tsdown --watch",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "tsdown": "^0.18.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "fflate": "^0.8.2"
  }
}
