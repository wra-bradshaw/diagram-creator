{
  "name": "typst-wasm",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./fonts": {
      "import": {
        "types": "./dist/fonts.d.mts",
        "default": "./dist/fonts.mjs"
      },
      "require": {
        "types": "./dist/fonts.d.cts",
        "default": "./dist/fonts.cjs"
      }
    },
    "./wasm": {
      "import": "./dist/typst_wasm_bg.wasm",
      "require": "./dist/typst_wasm_bg.wasm"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "moon run build",
    "dev": "moon run dev",
    "prepublishOnly": "moon run prepublishOnly",
    "test": "vitest run",
    "lint": "eslint src --max-warnings=0",
    "lint:fix": "eslint src --fix"
  },
  "devDependencies": {
    "@effect/eslint-plugin": "^0.3.2",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.2.0",
    "eslint": "^10.0.0",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "effect": "^3.19.16",
    "nanotar": "^0.2.0",
    "tsdown-plugin-worker": "^0.1.6"
  }
}
