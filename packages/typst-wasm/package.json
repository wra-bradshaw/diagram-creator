{
  "name": "typst-wasm",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./fonts": {
      "import": {
        "types": "./dist/fonts.d.mts",
        "default": "./dist/fonts.mjs"
      },
      "require": {
        "types": "./dist/fonts.d.cts",
        "default": "./dist/fonts.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "moon run build",
    "dev": "moon run dev",
    "prepublishOnly": "moon run prepublishOnly"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "rolldown-plugin-wasm": "^0.2.1",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "nanotar": "^0.2.0",
    "tsdown-plugin-worker": "^0.1.6"
  }
}
